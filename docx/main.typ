// Нумерация заголовков - функция для разных форматов по уровням
#set heading(numbering: (..nums) => {
  let arr = nums.pos()
  if arr.len() == 1 {
    // Первый уровень: "ГЛАВА 1."
    [ГЛАВА ]
    str(arr.at(0))
    [. ]
  } else {
    // Другие уровни: "1.1.", "1.1.1."
    arr.map(str).join(".")
    [. ]
  }
})

// Функция для проверки текста в контенте (для использования в show rules)
#let contains-text(content, search) = {
  if content.has("text") {
    content.text.contains(search)
  } else if content.has("children") {
    content.children.any(c => contains-text(c, search))
  } else if content.has("body") {
    contains-text(content.body, search)
  } else {
    false
  }
}

// Настройка заголовков первого уровня (глав)
#show heading.where(level: 1): it => {
  set text(size: 16pt, weight: "bold")
  // Проверяем, есть ли нумерация
  if it.numbering != none {
    // Получаем номер через counter
    let nums = counter(heading).at(it.location())
    // Формируем "ГЛАВА X."
    set align(center)
    [ГЛАВА ]
    str(nums.at(0))
    [. ]
    upper(it.body)
  } else {
    // Без нумерации
    // Проверяем, является ли это приложением
    if contains-text(it.body, "ПРИЛОЖЕНИЕ") {
      // Приложения выравниваем по правому краю
      set align(right)
      upper(it.body)
    } else {
      // ВВЕДЕНИЕ, ЗАКЛЮЧЕНИЕ и т.д. - по центру
      set align(center)
      upper(it.body)
    }
  }
  v(0.5em)
}

// Настройка заголовков второго уровня
#show heading.where(level: 2): it => {
  set text(size: 14pt, weight: "bold")
  if it.numbering != none {
    let nums = counter(heading).at(it.location())
    // Формируем "X.X."
    str(nums.at(0))
    [.]
    str(nums.at(1))
    [. ]
    it.body
  } else {
    it.body
  }
  v(0.3em)
}

// Настройка заголовков третьего уровня
#show heading.where(level: 3): it => {
  set text(size: 14pt, weight: "regular", style: "italic")
  if it.numbering != none {
    let nums = counter(heading).at(it.location())
    // Формируем "X.X.X."
    str(nums.at(0))
    [.]
    str(nums.at(1))
    [.]
    str(nums.at(2))
    [. ]
    it.body
  } else {
    it.body
  }
  v(0.2em)
}

// Кастомное оформление записей оглавления
// Решение: передать none как первый аргумент в indented(),
// а объединить prefix и inner вручную - это убирает висячий отступ
// it.inner() уже содержит fill (точки) и номер страницы
#show outline.entry: it => link(
  it.element.location(),
  it.indented(
    none, // убираем висячий отступ
    it.prefix() + it.inner(), // inner уже содержит fill и page
  ),
)

// Оглавление с правильным оформлением записей (без висячего отступа)
